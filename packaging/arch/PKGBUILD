# Maintainer: cupidwm contributors

pkgname=cupidwm
pkgver=1.0
pkgrel=1
pkgdesc='Compact X11 tiling window manager with IPC and built-in status modules'
arch=('x86_64')
url='https://github.com/cupidthecat/cupidwm'
license=('GPL3')
depends=('libx11' 'libxinerama' 'libxrandr' 'libxcursor' 'libxft' 'fontconfig')
makedepends=('make' 'gcc')
source=()
sha256sums=()

_repo_root="${startdir}/../.."

prepare() {
	rm -rf "$srcdir/cupidwm-src"
	mkdir -p "$srcdir/cupidwm-src"

	cd "$_repo_root"
	tar \
		--exclude='.git' \
		--exclude='build' \
		--exclude='cupidwm' \
		--exclude='cupidwmctl' \
		--exclude='packaging/arch/pkg' \
		--exclude='packaging/arch/src' \
		-cf - . | (cd "$srcdir/cupidwm-src" && tar -xf -)
}

build() {
	cd "$srcdir/cupidwm-src"
	make cupidwm cupidwmctl
}

package() {
	cd "$srcdir/cupidwm-src"

	install -Dm755 cupidwm "$pkgdir/usr/bin/cupidwm"
	install -Dm755 cupidwmctl "$pkgdir/usr/bin/cupidwmctl"

	install -Dm644 cupidwm.desktop "$pkgdir/usr/share/xsessions/cupidwm.desktop"
	install -d "$pkgdir/usr/share/man/man1"
	sed "s/VERSION/${pkgver}/g" < cupidwm.1 > "$pkgdir/usr/share/man/man1/cupidwm.1"
	sed "s/VERSION/${pkgver}/g" < cupidwmctl.1 > "$pkgdir/usr/share/man/man1/cupidwmctl.1"
	chmod 644 "$pkgdir/usr/share/man/man1/cupidwm.1" "$pkgdir/usr/share/man/man1/cupidwmctl.1"

	install -Dm644 completions/cupidwmctl.bash \
		"$pkgdir/usr/share/bash-completion/completions/cupidwmctl"
	install -Dm644 examples/sxhkd/cupidwm.sxhkdrc \
		"$pkgdir/usr/share/doc/$pkgname/examples/cupidwm.sxhkdrc"
	install -Dm644 examples/xinitrc \
		"$pkgdir/usr/share/doc/$pkgname/examples/xinitrc"
}
